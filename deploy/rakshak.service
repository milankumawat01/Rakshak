[Unit]
Description=Rakshak FastAPI Backend
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Rakshak/backend
Environment="PATH=/home/ubuntu/Rakshak/backend/venv/bin:/usr/bin"
EnvironmentFile=/home/ubuntu/Rakshak/.env
ExecStart=/home/ubuntu/Rakshak/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
